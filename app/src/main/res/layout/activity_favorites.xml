<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Favorite Movies"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/txtFavoritesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No favorite movies"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="16dp"
            android:background="#1E1E1E"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etMovieId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Movie ID"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#1E1E1E"
            android:padding="14dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etNewRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New Rating"
            android:inputType="numberDecimal"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#1E1E1E"
            android:padding="14dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnUpdateRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update Rating"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDeleteLast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Last Movie"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnBackFromFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home" />

    </LinearLayout>

</ScrollView>